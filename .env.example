# SMTP credentials for the contact form (GoDaddy / Workspace Email).
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_SECURE=true

# Full mailbox address and its password.
SMTP_USER=info@ashfaqbuttfitnesszone.com
SMTP_PASSWORD=

# Where inquiries are delivered, and the "From" address shown to recipients.
# For GoDaddy SMTP these should match SMTP_USER (the authenticated mailbox)
# or be an alias on the same account — otherwise the server may reject the send.
CONTACT_INBOX=info@ashfaqbuttfitnesszone.com
CONTACT_FROM="Ashfaq Butt Fitness Zone <info@ashfaqbuttfitnesszone.com>"
